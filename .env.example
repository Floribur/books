# PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/floslib?sslmode=disable

# HTTP server port (default: 8081)
PORT=8081

# Base URL used to build absolute og:image URLs for Open Graph meta tags.
# In production, set this to your public domain: https://library.example.com
# Default: http://localhost:8081
SITE_URL=http://localhost:8081

# Set to "development" to enable CORS for the Vite dev server at localhost:5173.
# Do NOT set in production — Go serves the React build from the same origin.
APP_ENV=development

# Google Books API key (used by the metadata enrichment background job).
# Obtained from: Google Cloud Console → APIs & Services → Credentials
# This key is NEVER exposed to the React frontend — Go backend only.
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here
